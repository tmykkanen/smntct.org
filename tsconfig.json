{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@public/*": ["public/*"],
			"@assets/*": ["src/assets/*"],
			"@components/*": ["src/components/*"],
			"@data/*": ["src/data/*"],
			"@icons/*": ["src/icons/*"],
			"@layouts/*": ["src/layouts/*"],
			"@pages/*": ["src/pages/*"],
			"@styles/*": ["src/styles/*"]
		}
	}
}
