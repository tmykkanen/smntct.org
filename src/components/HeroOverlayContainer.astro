---
import Prose from '@components/Prose.astro';
import { Image } from 'astro:assets';

interface Props {
	bgImg: ImageMetadata;
	id: string;
}

const { bgImg, id } = Astro.props as Props;

const bgImgUrl = bgImg ? `url(${bgImg.src})` : '';
// Animation inspired by https://www.youtube.com/watch?v=UmzFk68Bwdk
---

<!-- Container -->
<div
	class="hero-container"
	{id}
	x-data
	x-intersect:enter="$store.vis.on = false"
	x-intersect:leave="$store.vis.on = true"
>
	<div class="hero-container-content">
		<!-- Prose Wrapper -->
		<Prose>
			<!-- Overlay Overrides -->
			<div
				class="prose-h1:text-primary prose-a:text-primary prose-a:bg-[url(/src/assets/1x4-00adb5ff.png)] text-center"
			>
				<slot name="heading" />
			</div>
		</Prose>
	</div>
	<div class="hero-container-image bg-neutral"></div>
	<!-- <img src={bgImg.src} alt="alt" class="hero-container-image opacity-50" /> -->
	<Image
		src={bgImg}
		alt={'background image of a field'}
		class={'hero-container-image opacity-50'}
	/>
</div>

<style>
	.hero-container {
		display: grid;
		place-items: center;
		position: relative;
		height: 100svh;
		overflow-x: clip;
		padding-block: 7rem;
		margin-block-end: 3rem;
	}
	.hero-container-content {
		animation: fade-out linear;
		animation-timeline: view();
		animation-range: exit -200px;
	}
	.hero-container-image {
		grid-column: 1 / -1;
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		z-index: -1;

		animation: header-image-animation linear forwards;
		animation-timeline: view();
		animation-range: exit;
	}

	@keyframes fade-out {
		to {
			opacity: 0;
		}
	}

	@keyframes header-image-animation {
		25% {
			opacity: 0.5;
		}
		85%,
		100% {
			opacity: 0;
			transform: scale(3) translateY(0);
		}
	}
</style>
