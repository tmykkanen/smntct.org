---
import { Icon } from 'astro-icon/components';
import FullscreenMenuItems from './FullscreenMenuItems.astro';

import navData from '@data/navData.json';
const { menuItems } = navData;
---

<dialog id="fullscreenMenu" class="modal">
	<div class="modal-box bg-neutral size-full max-h-screen max-w-screen rounded-none px-0 py-0">
		<div class="flex items-center justify-between border-b border-b-neutral-200 px-4 py-3">
			<h3>
				<a href="/" class="btn btn-ghost text-primary text-2xl">
					<Icon name="tct_logo" class="text-4xl" />
					Southern MN TCT
				</a>
			</h3>

			<!-- Close Btn -->
			<form method="dialog">
				<button class="btn btn-xs btn-circle btn-ghost text-primary text-4xl">
					<span class="sr-only">Close</span>
					<Icon name="line-md:close-small" />
				</button>
			</form>
		</div>

		<!-- Menu -->
		<div class="text-primary overflow-y-auto p-4">
			<FullscreenMenuItems {menuItems} />
		</div>
	</div>
</dialog>
